{
  "name": "smoosh-cli",
  "version": "0.2.0",
  "description": "Bundle a local HTML site into a single self-contained file for sharing — inlines all assets, validates nothing is missed",
  "type": "module",
  "bin": {
    "smoosh": "./bin/smoosh.js"
  },
  "files": [
    "bin/",
    "lib/"
  ],
  "scripts": {
    "test": "node --test test/tests.mjs",
    "test:integration": "node --test test/integration.mjs",
    "test:all": "node --test test/tests.mjs test/integration.mjs"
  },
  "license": "MIT",
  "dependencies": {
    "playwright": "^1.60.0"
  }
}
